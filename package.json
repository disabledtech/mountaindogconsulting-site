{
  "name": "mountaindog-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mountain Dog Consulting marketing site — static, accessibility-first, near-zero-JS.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "deploy": "wrangler deploy",
    "audit:axe": "axe ./dist --dir",
    "audit:pa11y": "pa11y-ci --sitemap ./dist/sitemap-index.xml",
    "audit:lhci": "lhci autorun",
    "audit:lhci:mobile": "lhci autorun --config=./lighthouserc.mobile.json"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.2",
    "astro-compressor": "^1.3.0",
    "remark-reading-time": "^2.1.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "lightningcss": "^1.32.0",
    "pa11y-ci": "^4.1.0",
    "wrangler": "^4.88.0"
  },
  "overrides": {
    "tmp": "^0.2.4",
    "inquirer": "^9.3.7",
    "external-editor": "^3.1.0",
    "lodash": "^4.18.1"
  }
}
